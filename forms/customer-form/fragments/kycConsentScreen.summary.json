      "items": {
        "panelcontainer": {
          "name": "kycIdentificationPanel",
          "fieldType": "panel",
          "label": "<p>kycIdentificationPanel</p>",
          "events": {
            "custom:setProperty": "$event.payload"
          },
          "items": {
            "panelcontainer": {
              "name": "centralKYCIdentificationPanel",
              "fieldType": "panel",
