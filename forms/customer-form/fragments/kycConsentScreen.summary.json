        "custom:setProperty": "$event.payload"
      }
    },
    "textinput_1677002495": {
      "name": "hiddenVkycConsentDate",
      "dataRef": "$.vkycConsentDate",
      "fieldType": "text-input",
      "type": "string",
      "label": "<p>hiddenVkycConsentDate</p>",
      "visible": false,
      "events": {
        "custom:setProperty": "$event.payload"
      }
    }
